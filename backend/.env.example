# Provider selection
TEXT_MODEL_PROVIDER=openai
VISION_MODEL_PROVIDER=openai
EMBEDDING_PROVIDER=local

# Experimental local Codex CLI provider.
# Set TEXT_MODEL_PROVIDER=codex_cli to use the machine's `codex exec` login.
CODEX_CLI_COMMAND=codex
CODEX_CLI_MODEL=
CODEX_CLI_TIMEOUT_SECONDS=180

# OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_JSON_MODEL=gpt-4o-mini
OPENAI_NOTE_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=2
ENABLE_OPENAI_VISION=true
MAX_OPENAI_IMAGE_MB=10
OPENAI_STORE_RESPONSES=false
MAX_NOTE_IMAGE_ATTACHMENTS=6

# Optional fallback providers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_NOTE=deepseek-chat
DEEPSEEK_MODEL_JSON=deepseek-chat

GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
ENABLE_GEMINI_VISION=false

OBSIDIAN_VAULT_PATH=../obsidian_vault
OBSIDIAN_NOTE_DIR=02_ReadingNotes
VECTOR_BACKEND=chroma

# Adaptive Layout-Aware RAG v2
RAG_ADAPTIVE_ENABLED=true
RAG_QUERY_ANALYZER_USE_LLM=false
RAG_ABSTRACT_DETECTION_ENABLED=true
RAG_ABSTRACT_DEFAULT_MODE=downweight
RAG_ABSTRACT_DOWNWEIGHT_FACTOR=0.75
RAG_ABSTRACT_MAX_COMPLEX_EVIDENCE=1
RAG_SIMPLE_VECTOR_TOP_K=20
RAG_SIMPLE_KEYWORD_TOP_K=20
RAG_SIMPLE_FINAL_TOP_K=6
RAG_COMPLEX_SECTION_TOP_K=5
RAG_COMPLEX_MAX_EVIDENCE=14
RAG_COMPLEX_MAX_RETRIEVAL_ROUNDS=2
RAG_RERANKER=rule_weighted_v1
RAG_ENABLE_OPTIONAL_CROSS_ENCODER=false
